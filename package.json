{
  "name": "vite-react-template",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp build",
    "codecheck": "pnpm run typecheck && pnpm run lint && pnpm run format && pnpm run ls-lint && pnpm run knip && pnpm run test",
    "dev": "vp dev",
    "format": "vp fmt --check",
    "format:fix": "vp fmt",
    "knip": "knip",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "ls-lint": "ls-lint",
    "preinstall": "npx only-allow pnpm",
    "preview": "vp preview",
    "test": "vp test run",
    "test:watch": "vp test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.1.0"
  },
  "devDependencies": {
    "@ls-lint/ls-lint": "2.3.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "knip": "6.25.0",
    "lefthook": "2.1.9",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vite-plus": "0.2.3"
  },
  "packageManager": "pnpm@11.10.0"
}
